{
  "name": "quickstore-backend",
  "version": "1.0.0",
  "description": "QuickStore Backend API",
  "author": "QuickStore Team",
  "license": "MIT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "pm2 start server.js --name quickstore-api",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "db:drop": "node scripts/drop-db.js",
    "db:create": "node scripts/create-db.js",
    "db:reset": "npm run db:drop && npm run db:create && npm run migrate && npm run seed"
  },
  "dependencies": {
    "express": "4.18.2",
    "mongoose": "8.0.3",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "dotenv": "16.3.1",
    "cors": "2.8.5",
    "helmet": "7.1.0",
    "express-rate-limit": "7.1.5",
    "express-validator": "7.0.1",
    "multer": "1.4.5-lts.1",
    "sharp": "0.33.0",
    "nodemailer": "6.9.7",
    "winston": "3.11.0",
    "morgan": "1.10.0",
    "compression": "1.7.4",
    "socket.io": "4.5.4",
    "redis": "4.6.11",
    "bull": "4.11.5",
    "stripe": "14.9.0",
    "paypal-rest-sdk": "1.8.1",
    "twilio": "4.19.3",
    "aws-sdk": "2.1515.0",
    "googleapis": "129.0.0",
    "facebook-nodejs-business-sdk": "18.0.2",
    "openai": "4.20.1",
    "axios": "1.6.2",
    "lodash": "4.17.21",
    "moment": "2.29.4",
    "uuid": "9.0.1",
    "slugify": "1.6.6",
    "csv-parser": "3.0.0",
    "exceljs": "4.4.0",
    "pdfkit": "0.14.0",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.0"
  },
  "devDependencies": {
    "nodemon": "3.0.2",
    "jest": "29.7.0",
    "supertest": "6.3.3",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.0",
    "prettier": "3.1.1",
    "husky": "8.0.3",
    "lint-staged": "15.2.0",
    "@types/node": "20.10.5",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.5",
    "@types/bcryptjs": "2.4.6",
    "@types/multer": "1.4.11",
    "@types/nodemailer": "6.4.14"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}